{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "rootDir": "src/ts",
    "outDir": "dist/js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES6"]
  },
  "include": ["src/ts/main.ts"]
}
